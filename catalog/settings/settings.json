{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(pnpm run *)",
      "Bash(yarn run *)",
      "Bash(bun run *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Read(./**)",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Read(./.ssh/**)",
      "Read(./.aws/**)",
      "Write(./.env*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(chmod -R 777 *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(npm publish*)",
      "Bash(docker push*)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": ["filesystem", "memory", "fetch"],
  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30
}
